@page "/statistics"
@rendermode InteractiveServer
@using NutritionApp.Controllers
@using NutritionApp.Models
@using NutritionApp.Services
@inject NavigationManager Nav
@inject SessionService Session

<div style="text-align:center; margin-top:50px;">

    <h3>Statistics</h3>

    <table style="margin:auto;">
        <tr>
            <td><label>From:</label></td>
            <td><input type="date" @bind="startDate" /></td>
        </tr>
        <tr>
            <td><label>To:</label></td>
            <td><input type="date" @bind="endDate" /></td>
        </tr>
        <tr>
            <td colspan="2" style="text-align:center; padding-top:8px;">
                <button @onclick="Calculate">Calculate</button>
                <button @onclick="GoBack">Back to Dashboard</button>
            </td>
        </tr>
    </table>

    @if (errorMessage != "")
    {
        <p style="color:red;">@errorMessage</p>
    }

    @if (calculated)
    {
        <br />
        <table style="margin:auto; text-align:left;">
            <tr>
                <td><b>Total Menus:</b></td>
                <td>@totalMenus</td>
            </tr>
            <tr>
                <td><b>Days Tracked:</b></td>
                <td>@totalDays</td>
            </tr>
            <tr>
                <td><b>Daily Goal:</b></td>
                <td>@dailyGoal kcal</td>
            </tr>
            <tr>
                <td><b>Days Goal Met:</b></td>
                <td>@daysGoalMet / @totalDays</td>
            </tr>
            <tr>
                <td><b>Total Calories:</b></td>
                <td>@Math.Round(totalCalories, 1) kcal</td>
            </tr>
            <tr>
                <td><b>Avg/Day Calories:</b></td>
                <td>@Math.Round(avgCalories, 1) kcal (Goal: @dailyGoal)</td>
            </tr>
            <tr>
                <td><b>Total Protein:</b></td>
                <td>@Math.Round(totalProtein, 1) g</td>
            </tr>
            <tr>
                <td><b>Avg/Day Protein:</b></td>
                <td>@Math.Round(avgProtein, 1) g</td>
            </tr>
            <tr>
                <td><b>Total Carbs:</b></td>
                <td>@Math.Round(totalCarbs, 1) g</td>
            </tr>
            <tr>
                <td><b>Avg/Day Carbs:</b></td>
                <td>@Math.Round(avgCarbs, 1) g</td>
            </tr>
            <tr>
                <td><b>Total Fat:</b></td>
                <td>@Math.Round(totalFat, 1) g</td>
            </tr>
            <tr>
                <td><b>Avg/Day Fat:</b></td>
                <td>@Math.Round(avgFat, 1) g</td>
            </tr>
        </table>

        <br />
        <h4>Daily Breakdown</h4>
        <table border="1" style="margin:auto;">
            <tr>
                <th>Date</th>
                <th>Calories</th>
                <th>Status</th>
                <th>Protein</th>
                <th>Carbs</th>
                <th>Fat</th>
            </tr>
            @foreach (var day in GetCurrentPage())
            {
                <tr>
                    <td>@day.Date</td>
                    <td>@Math.Round(day.Calories, 0) kcal</td>
                    <td>@day.Status</td>
                    <td>@Math.Round(day.Protein, 1) g</td>
                    <td>@Math.Round(day.Carbs, 1) g</td>
                    <td>@Math.Round(day.Fat, 1) g</td>
                </tr>
            }
        </table>

        <br />
        <button @onclick="PreviousPage" disabled="@(currentPage == 0)">Previous</button>
        <span> Page @(currentPage + 1) of @TotalPages </span>
        <button @onclick="NextPage" disabled="@(currentPage >= TotalPages - 1)">Next</button>
    }

</div>

@code {
    private DateTime startDate = DateTime.Today.AddDays(-15);
    private DateTime endDate = DateTime.Today;
    private string errorMessage = "";
    private bool calculated = false;
    private int currentPage = 0;
    private int pageSize = 10;

    private int totalMenus = 0;
    private int totalDays = 0;
    private int daysGoalMet = 0;
    private double dailyGoal = 0;
    private double totalCalories = 0;
    private double avgCalories = 0;
    private double totalProtein = 0;
    private double avgProtein = 0;
    private double totalCarbs = 0;
    private double avgCarbs = 0;
    private double totalFat = 0;
    private double avgFat = 0;

    private List<DayStats> dailyBreakdown = new List<DayStats>();
    private MenuController menuCtrl = new MenuController();
    private NutritionService nutritionService = new NutritionService();

    private class DayStats
    {
        public string Date { get; set; }
        public double Calories { get; set; }
        public double Protein { get; set; }
        public double Carbs { get; set; }
        public double Fat { get; set; }
        public string Status { get; set; }
    }

    private List<DayStats> GetCurrentPage()
    {
        return dailyBreakdown.Skip(currentPage * pageSize).Take(pageSize).ToList();
    }

    private int TotalPages => (int)Math.Ceiling((double)dailyBreakdown.Count / pageSize);

    private void PreviousPage()
    {
        if (currentPage > 0)
            currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages - 1)
            currentPage++;
    }

    private void Calculate()
    {
        errorMessage = "";
        calculated = false;
        currentPage = 0;

        if (startDate > endDate)
        {
            errorMessage = "Start date must be before end date.";
            return;
        }

        User user = Session.CurrentUser;
        dailyGoal = nutritionService.CalculateDailyCalories(user);

        List<Menu> allMenus = menuCtrl.GetMenusByUser(user.Id);
        List<Menu> filtered = new List<Menu>();

        foreach (Menu m in allMenus)
        {
            if (m.Date.Date >= startDate.Date && m.Date.Date <= endDate.Date)
                filtered.Add(m);
        }

        if (filtered.Count == 0)
        {
            errorMessage = "No menus found for that date range.";
            return;
        }

        totalMenus = filtered.Count;
        totalCalories = 0;
        totalProtein = 0;
        totalCarbs = 0;
        totalFat = 0;
        daysGoalMet = 0;
        dailyBreakdown = new List<DayStats>();

        List<string> days = new List<string>();
        foreach (Menu m in filtered)
        {
            string day = m.Date.Date.ToString("yyyy-MM-dd");
            if (!days.Contains(day))
                days.Add(day);

            totalCalories += m.TotalCalories;
            totalProtein += m.TotalProtein;
            totalCarbs += m.TotalCarbohydrates;
            totalFat += m.TotalFat;
        }

        totalDays = days.Count;

        foreach (string day in days)
        {
            double dayCalories = 0;
            double dayProtein = 0;
            double dayCarbs = 0;
            double dayFat = 0;

            foreach (Menu m in filtered)
            {
                if (m.Date.Date.ToString("yyyy-MM-dd") == day)
                {
                    dayCalories += m.TotalCalories;
                    dayProtein += m.TotalProtein;
                    dayCarbs += m.TotalCarbohydrates;
                    dayFat += m.TotalFat;
                }
            }

            bool goalMet = Math.Abs(dayCalories - dailyGoal) <= 100;
            if (goalMet) daysGoalMet++;

            dailyBreakdown.Add(new DayStats
            {
                Date = day,
                Calories = dayCalories,
                Protein = dayProtein,
                Carbs = dayCarbs,
                Fat = dayFat,
                Status = goalMet ? "OK" : "MISS"
            });
        }

        avgCalories = totalCalories / totalDays;
        avgProtein = totalProtein / totalDays;
        avgCarbs = totalCarbs / totalDays;
        avgFat = totalFat / totalDays;

        calculated = true;
    }

    private void GoBack() => Nav.NavigateTo("/dashboard");
}