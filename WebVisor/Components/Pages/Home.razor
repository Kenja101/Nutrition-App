@page "/"
@rendermode InteractiveServer
@using NutritionApp.Controllers
@using NutritionApp.Models
@using NutritionApp.Services
@inject NavigationManager Nav
@inject SessionService Session

<div style="text-align:center; margin-top:50px;">
    <h1>Welcome to Nutrition App</h1>
    <p>Please login to continue.</p>

    <table style="margin:auto;">
        <tr>
            <td><label>Email:</label></td>
            <td><input type="text" @bind="email" /></td>
        </tr>
        <tr>
            <td><label>Password:</label></td>
            <td><input type="password" @bind="password" /></td>
        </tr>
        <tr>
            <td colspan="2" style="text-align:center; padding-top:8px;">
                <button @onclick="DoLogin">Login</button>
            </td>
        </tr>
    </table>

    @if (errorMessage != "")
    {
        <p style="color:red;">@errorMessage</p>
    }
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";
    private UserController userCtrl = new UserController();

    // intenta hacer login y redirige segun el rol
    private void DoLogin()
    {
        if (email == "" || password == "")
        {
            errorMessage = "Please enter email and password.";
            return;
        }

        User user = userCtrl.Login(email, password);

        if (user == null)
       {
          errorMessage = "Email or password is wrong or account is inactive.";
          return;
         }

        Session.CurrentUser = user;

        if (user.Role == "Admin")
        {
            Nav.NavigateTo("/admin");
        }
        else
        {
            Nav.NavigateTo("/dashboard");
        }
    }
}