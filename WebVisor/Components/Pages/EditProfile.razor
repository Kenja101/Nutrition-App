@page "/editprofile"
@rendermode InteractiveServer
@using NutritionApp.Controllers
@using NutritionApp.Models
@using NutritionApp.Services
@inject NavigationManager Nav
@inject SessionService Session

<div style="text-align:center; margin-top:50px;">

    <h3>Edit Profile</h3>

    <table style="margin:auto;">
        <tr>
            <td><label>Full Name:</label></td>
            <td><input type="text" @bind="fullName" /></td>
        </tr>
        <tr>
            <td><label>Email:</label></td>
            <td><input type="text" @bind="email" /></td>
        </tr>
        <tr>
            <td><label>Age:</label></td>
            <td><input type="number" @bind="age" /></td>
        </tr>
        <tr>
            <td><label>Weight (kg):</label></td>
            <td><input type="number" @bind="weight" /></td>
        </tr>
        <tr>
            <td><label>Height (cm):</label></td>
            <td><input type="number" @bind="height" /></td>
        </tr>
        <tr>
            <td><label>Activity Level:</label></td>
            <td>
                <select @bind="activityLevel">
                    <option value="Sedentary">Sedentary</option>
                    <option value="Light">Light</option>
                    <option value="Moderate">Moderate</option>
                    <option value="Active">Active</option>
                </select>
            </td>
        </tr>
        <tr>
            <td><label>Goal:</label></td>
            <td>
                <select @bind="goal">
                    <option value="MaintainWeight">Maintain Weight</option>
                    <option value="LoseFat">Lose Fat</option>
                    <option value="GainMuscle">Gain Muscle</option>
                </select>
            </td>
        </tr>
        <tr>
            <td><label>Diet Type:</label></td>
            <td>
                <select @bind="dietType">
                    <option value="Standard">Standard</option>
                    <option value="Keto">Keto</option>
                    <option value="Vegetarian">Vegetarian</option>
                </select>
            </td>
        </tr>
        <tr>
            <td colspan="2" style="text-align:center; padding-top:8px;">
                <button @onclick="SaveChanges">Save Changes</button>
                <button @onclick="GoBack">Back to Dashboard</button>
            </td>
        </tr>
    </table>

    @if (message != "")
    {
        <p>@message</p>
    }

</div>

@code {
    private string fullName = "";
    private string email = "";
    private int age = 0;
    private double weight = 0;
    private double height = 0;
    private string activityLevel = "Sedentary";
    private string goal = "MaintainWeight";
    private string dietType = "Standard";
    private string message = "";

    private UserController userCtrl = new UserController();

    protected override void OnInitialized()
    {
        User user = Session.CurrentUser;
        fullName = user.FullName;
        email = user.Email;
        age = user.Age;
        weight = user.Weight;
        height = user.Height;
        activityLevel = user.ActivityLevel;
        goal = user.Goal;
        dietType = user.DietType;
    }

    private void SaveChanges()
    {
        User user = Session.CurrentUser;
        user.FullName = fullName;
        user.Email = email;
        user.Age = age;
        user.Weight = weight;
        user.Height = height;
        user.ActivityLevel = activityLevel;
        user.Goal = goal;
        user.DietType = dietType;

        userCtrl.UpdateUser(user);
        Session.CurrentUser = user;
        message = "Profile updated successfully.";
    }

    private void GoBack() => Nav.NavigateTo("/dashboard");
}