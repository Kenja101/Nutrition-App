@page "/adminstats"
@rendermode InteractiveServer
@using NutritionApp.Controllers
@using NutritionApp.Models
@inject NavigationManager Nav

<div style="text-align:center; margin-top:50px;">

    <h3>Global Statistics</h3>

    <button @onclick="GoBack">Back to Admin Panel</button>

    <br /><br />

    <table style="margin:auto;">
        <tr>
            <td><label>From:</label></td>
            <td><input type="date" @bind="startDate" /></td>
        </tr>
        <tr>
            <td><label>To:</label></td>
            <td><input type="date" @bind="endDate" /></td>
        </tr>
        <tr>
            <td colspan="2" style="text-align:center; padding-top:8px;">
                <button @onclick="Calculate">Calculate</button>
            </td>
        </tr>
    </table>

    @if (errorMessage != "")
    {
        <p style="color:red;">@errorMessage</p>
    }

    @if (calculated)
    {
        <br />
        <h4>Most Consumed Products</h4>
        <table border="1" style="margin:auto;">
            <tr>
                <th>Product</th>
                <th>Times Used</th>
            </tr>
            @foreach (var item in GetProductsPage())
            {
                <tr>
                    <td>@item.Key</td>
                    <td>@item.Value</td>
                </tr>
            }
        </table>
        <br />
        <button @onclick="PrevProducts" disabled="@(productsPage == 0)">Previous</button>
        <span> Page @(productsPage + 1) of @TotalProductsPages </span>
        <button @onclick="NextProducts" disabled="@(productsPage >= TotalProductsPages - 1)">Next</button>

        <br /><br />
        <h4>Diet Type Distribution</h4>
        <table border="1" style="margin:auto;">
            <tr>
                <th>Diet Type</th>
                <th>Users</th>
                <th>Percentage</th>
            </tr>
            @foreach (var item in GetDietPage())
            {
                <tr>
                    <td>@item.Key</td>
                    <td>@item.Value</td>
                    <td>@Math.Round((double)item.Value / totalUsers * 100, 1) %</td>
                </tr>
            }
        </table>
        <br />
        <button @onclick="PrevDiet" disabled="@(dietPage == 0)">Previous</button>
        <span> Page @(dietPage + 1) of @TotalDietPages </span>
        <button @onclick="NextDiet" disabled="@(dietPage >= TotalDietPages - 1)">Next</button>

        <br /><br />
        <h4>Users with Most Menus</h4>
        <table border="1" style="margin:auto;">
            <tr>
                <th>User</th>
                <th>Menus</th>
            </tr>
            @foreach (var item in GetUsersPage())
            {
                <tr>
                    <td>@item.Key</td>
                    <td>@item.Value</td>
                </tr>
            }
        </table>
        <br />
        <button @onclick="PrevUsers" disabled="@(usersPage == 0)">Previous</button>
        <span> Page @(usersPage + 1) of @TotalUsersPages </span>
        <button @onclick="NextUsers" disabled="@(usersPage >= TotalUsersPages - 1)">Next</button>
    }

</div>

@code {
    private DateTime startDate = DateTime.Today.AddDays(-30);
    private DateTime endDate = DateTime.Today;
    private string errorMessage = "";
    private bool calculated = false;
    private int totalUsers = 0;
    private int pageSize = 5;

    private int productsPage = 0;
    private int dietPage = 0;
    private int usersPage = 0;

    private List<KeyValuePair<string, int>> topProducts = new List<KeyValuePair<string, int>>();
    private List<KeyValuePair<string, int>> dietDistribution = new List<KeyValuePair<string, int>>();
    private List<KeyValuePair<string, int>> topUsers = new List<KeyValuePair<string, int>>();

    private MenuController menuCtrl = new MenuController();
    private UserController userCtrl = new UserController();
    private FoodController foodCtrl = new FoodController();

    private List<KeyValuePair<string, int>> GetProductsPage() =>
        topProducts.Skip(productsPage * pageSize).Take(pageSize).ToList();
    private int TotalProductsPages => (int)Math.Ceiling((double)topProducts.Count / pageSize);
    private void PrevProducts() { if (productsPage > 0) productsPage--; }
    private void NextProducts() { if (productsPage < TotalProductsPages - 1) productsPage++; }

    private List<KeyValuePair<string, int>> GetDietPage() =>
        dietDistribution.Skip(dietPage * pageSize).Take(pageSize).ToList();
    private int TotalDietPages => (int)Math.Ceiling((double)dietDistribution.Count / pageSize);
    private void PrevDiet() { if (dietPage > 0) dietPage--; }
    private void NextDiet() { if (dietPage < TotalDietPages - 1) dietPage++; }

    private List<KeyValuePair<string, int>> GetUsersPage() =>
        topUsers.Skip(usersPage * pageSize).Take(pageSize).ToList();
    private int TotalUsersPages => (int)Math.Ceiling((double)topUsers.Count / pageSize);
    private void PrevUsers() { if (usersPage > 0) usersPage--; }
    private void NextUsers() { if (usersPage < TotalUsersPages - 1) usersPage++; }

    private void Calculate()
    {
        errorMessage = "";
        calculated = false;
        productsPage = 0;
        dietPage = 0;
        usersPage = 0;
        topProducts = new List<KeyValuePair<string, int>>();
        dietDistribution = new List<KeyValuePair<string, int>>();
        topUsers = new List<KeyValuePair<string, int>>();

        if (startDate > endDate)
        {
            errorMessage = "Start date must be before end date.";
            return;
        }

        List<User> users = userCtrl.GetAll();
        totalUsers = users.Count;

        Dictionary<string, int> productCount = new Dictionary<string, int>();
        Dictionary<string, int> userMenuCount = new Dictionary<string, int>();

        foreach (User user in users)
        {
            List<Menu> menus = menuCtrl.GetMenusByUser(user.Id);
            int count = 0;

            foreach (Menu m in menus)
            {
                if (m.Date.Date >= startDate.Date && m.Date.Date <= endDate.Date)
                {
                    count++;
                    foreach (MenuItem item in m.Items)
                    {
                        FoodProduct food = foodCtrl.GetById(item.FoodProductId);
                        string foodName = food != null ? food.Name : item.FoodName;
                        if (foodName == "Food item" || foodName == "") continue;
                        if (productCount.ContainsKey(foodName))
                            productCount[foodName]++;
                        else
                            productCount[foodName] = 1;
                    }
                }
            }

            if (count > 0)
                userMenuCount[user.FullName] = count;
        }

        Dictionary<string, int> diets = new Dictionary<string, int>();
        foreach (User user in users)
        {
            if (user.DietType == "" || user.DietType == null) continue;
            if (diets.ContainsKey(user.DietType))
                diets[user.DietType]++;
            else
                diets[user.DietType] = 1;
        }

        topProducts = new List<KeyValuePair<string, int>>(productCount);
        topProducts.Sort((a, b) => b.Value.CompareTo(a.Value));

        dietDistribution = new List<KeyValuePair<string, int>>(diets);

        topUsers = new List<KeyValuePair<string, int>>(userMenuCount);
        topUsers.Sort((a, b) => b.Value.CompareTo(a.Value));

        calculated = true;
    }

    private void GoBack() => Nav.NavigateTo("/admin");
}